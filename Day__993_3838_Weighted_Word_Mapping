class Solution {
public:
    string mapWordWeights(vector<string>& words, vector<int>& weights) {
        string result;
        for(auto&str:words){
            int val=0;
            for(auto&ch:str){
                val=(val+weights[ch-'a'])%26;
            }
            result+=(25-val)+'a';
        }
        return result;
    }
};
