class Solution {
public:
    bool isGood(vector<int>& nums) {
        int n=nums.size();
        sort(nums.begin(),nums.end());
        int cnt=1;
        for(int i=0;i<n-1;i++){
            if(nums[i]==cnt){
                cnt++;
            }else return false;
        }
        if(nums.back()==cnt-1) return true;
        return false;
    }
};
